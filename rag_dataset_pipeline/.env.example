# OpenAI-compatible chat-completions endpoint used by extract_anchors.py and
# generate_rag_qa.py. gpt-4o is a suitable default for both anchor extraction
# and RAG QA generation.
OPENAI_BASE_URL=https://api.example.com/v1
OPENAI_API_KEY=replace-with-api-key
OPENAI_MODEL=gpt-4o

# Optional model settings for retrieval and related experiments.
# These are documented here for reproducibility; the standalone dataset
# pipeline does not load them unless retrieval or rewrite steps are built around
# it.
RETRIEVAL_EMBEDDING_MODEL=BAAI/bge-m3
RETRIEVAL_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
BGE_M3_PATH=../bge-m3
BGE_RERANKER_PATH=../bge-reranker-v2-m3
REWRITE_MODEL_GLM=THUDM/GLM-4-9B-0414
REWRITE_MODEL_QWEN=Qwen/Qwen2.5-7B-Instruct
REWRITE_MODEL_LLAMA=llama-3.1-8b-instruct
FEDDISP_BASE_MODEL=long-t5-tglobal-base
SEMANTIC_SIMILARITY_MODEL=all-MiniLM-L6-v2
